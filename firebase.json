{
  "functions": {
    "source": "functions",
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" install"
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "_archive/**"
    ],
    "headers": [
      {
        "source": "/admin/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/contact",
        "function": "contact"
      },
      {
        "source": "/api/newsletter",
        "function": "newsletter"
      },
      {
        "source": "/api/seed-projects",
        "function": "seedProjects"
      },
      {
        "source": "/api/backfill-company-reviews",
        "function": "backfillCompanyReviews"
      },
      {
        "source": "/api/publish-auto-reviews",
        "function": "publishAutoReviews"
      },
      {
        "source": "/api/bootstrap-admin",
        "function": "bootstrapAdmin"
      },
      {
        "source": "/api/generate-blog-post",
        "function": "generateBlogPost"
      },
      {
        "source": "/sitemap-blog.xml",
        "function": "sitemap"
      },
      {
        "source": "/projects/**",
        "destination": "/project-detail.html"
      },
      {
        "source": "/blog",
        "function": "blogIndex"
      },
      {
        "source": "/blog/**",
        "function": "blogArticle"
      }
    ]
  }
}
