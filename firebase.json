{
  "functions": {
    "source": "functions",
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" install"
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "_archive/**"
    ],
    "headers": [
      {
        "source": "/admin/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/contact",
        "function": {
          "functionId": "contact",
          "region": "europe-west2"
        }
      },
      {
        "source": "/api/newsletter",
        "function": {
          "functionId": "newsletter",
          "region": "europe-west2"
        }
      },
      {
        "source": "/api/seed-projects",
        "function": {
          "functionId": "seedProjects",
          "region": "europe-west2"
        }
      },
      {
        "source": "/api/backfill-company-reviews",
        "function": {
          "functionId": "backfillCompanyReviews",
          "region": "europe-west2"
        }
      },
      {
        "source": "/api/publish-auto-reviews",
        "function": {
          "functionId": "publishAutoReviews",
          "region": "europe-west2"
        }
      },
      {
        "source": "/api/bootstrap-admin",
        "function": {
          "functionId": "bootstrapAdmin",
          "region": "europe-west2"
        }
      },
      {
        "source": "/api/generate-blog-post",
        "function": {
          "functionId": "generateBlogPost",
          "region": "europe-west2"
        }
      },
      {
        "source": "/sitemap-blog.xml",
        "function": {
          "functionId": "sitemap",
          "region": "europe-west2"
        }
      },
      {
        "source": "/projects/**",
        "destination": "/project-detail.html"
      },
      {
        "source": "/blog",
        "function": {
          "functionId": "blogIndex",
          "region": "europe-west2"
        }
      },
      {
        "source": "/blog/**",
        "function": {
          "functionId": "blogArticle",
          "region": "europe-west2"
        }
      }
    ]
  }
}
